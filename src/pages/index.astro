---
import '../styles/global.css';
import { WorkspaceApp } from '../components/WorkspaceApp';
---

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>VisionLab | Workspace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        body {
            background-color: #0a0a0a;
            color: #e5e2e1;
            font-family: 'Outfit', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(53, 53, 52, 0.4);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
        }
        /* Glassmorphism iOS exato — igual à Landing Page */
        .navbar-glass {
            background: rgba(15, 15, 15, 0.4);
            backdrop-filter: blur(24px) saturate(1.8);
            -webkit-backdrop-filter: blur(24px) saturate(1.8);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.15);
        }
        .ghost-border {
            border: 1px solid rgba(88, 66, 53, 0.15);
        }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(226, 114, 65, 0.1); border-radius: 10px; }

        /* Chat history items */
        .chat-history-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid transparent;
        }
        .chat-history-item:hover {
            background: rgba(255,255,255,0.04);
            border-color: rgba(226,114,65,0.1);
        }
        .chat-history-item.active {
            background: rgba(226,114,65,0.08);
            border-color: rgba(226,114,65,0.2);
        }
        .chat-history-title {
            font-size: 11px;
            color: #a1a1aa;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 140px;
            flex: 1;
        }
        .chat-history-delete {
            opacity: 0;
            color: #71717a;
            transition: opacity 0.15s;
            background: none;
            border: none;
            cursor: pointer;
            padding: 2px;
            line-height: 1;
        }
        .chat-history-item:hover .chat-history-delete {
            opacity: 1;
        }

        /* ── Mobile overlay para sidebar ── */
        #mobile-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 49;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }
        #mobile-overlay.active { display: block; }

        @media (max-width: 767px) {
            /* Sidebar vira drawer fixo no mobile */
            #left-sidebar {
                position: fixed !important;
                left: 0;
                top: 0;
                bottom: 0;
                height: 100vh !important;
                width: 78vw !important;
                max-width: 300px;
                z-index: 50;
                transform: translateX(-110%);
                transition: transform 0.3s cubic-bezier(0.4,0,0.2,1) !important;
                padding: 1rem !important;
            }
            #left-sidebar.mobile-open {
                transform: translateX(0) !important;
            }
            /* Esconde painel de preview no mobile */
            #preview-root {
                display: none !important;
            }
            /* Esconde o botão do preview panel no mobile */
            #right-menu-toggle {
                display: none;
            }
        }
    </style>
</head>
<body class="h-screen overflow-hidden flex flex-col selection:bg-[#e27241]/30 selection:text-white">

    <!-- Auth guard -->
    <script>
        if (!localStorage.getItem('visionlabs_token')) {
            window.location.href = '/login';
        }
    </script>

    <!-- Top Navigation — glassmorphism iOS -->
    <header class="navbar-glass w-full h-16 sticky top-0 z-50 flex justify-between items-center px-8 border-b border-white/10">
        <div class="flex items-center gap-6">
            <button id="menu-toggle" class="text-zinc-400 hover:text-[#e27241] transition-colors flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl">menu</span>
            </button>
            <span class="text-lg font-black text-white tracking-tighter uppercase">VisionLabs</span>
            <nav class="hidden md:flex gap-8">
                <a class="text-[#e27241] font-bold border-b-2 border-[#e27241] uppercase tracking-widest text-[10px] py-1" href="/">Models</a>
                <a class="text-zinc-400 font-medium uppercase tracking-widest text-[10px] py-1 hover:text-[#e27241] transition-colors" href="/reference">Reference</a>
                <a class="text-zinc-400 font-medium uppercase tracking-widest text-[10px] py-1 hover:text-[#e27241] transition-colors" href="/docs">API</a>
            </nav>
        </div>
        <div class="flex items-center gap-4">
            <button id="right-menu-toggle" class="text-zinc-400 hover:text-[#e27241] transition-colors flex items-center justify-center mr-2">
                <span class="material-symbols-outlined text-xl">dock_to_right</span>
            </button>
            <div class="relative group mt-1">
                <span class="material-symbols-outlined text-zinc-400 cursor-pointer hover:text-[#e27241] transition-colors">notifications</span>
                <span class="absolute top-0 right-0 w-2 h-2 bg-[#e27241] rounded-full"></span>
            </div>
            <div class="flex items-center gap-3 pl-4 border-l border-white/10">
                <div class="w-8 h-8 rounded-full overflow-hidden border border-[#e27241]/20">
                    <img class="w-full h-full object-cover" src="/media/chat/avatar1.jpg" alt="User Profile"/>
                </div>
            </div>
        </div>
    </header>

    <!-- Overlay mobile para fechar sidebar -->
    <div id="mobile-overlay"></div>

    <div class="flex flex-1 overflow-hidden relative">
        <!-- Misty Background -->
        <div class="absolute top-0 left-0 w-full h-full pointer-events-none z-0 overflow-hidden">
            <div class="absolute -top-1/4 -right-1/4 w-1/2 h-1/2 bg-[#e27241]/5 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-0 left-0 w-full h-full opacity-20 grayscale pointer-events-none">
                <img class="w-full h-full object-cover mix-blend-overlay" src="/media/chat/mist-bg.jpg" alt=""/>
            </div>
        </div>

        <!-- Sidebar -->
        <aside id="left-sidebar" class="h-screen w-64 bg-[#0a0a0a] border-r border-[#e27241]/15 flex flex-col p-4 gap-2 z-10 shadow-[0_0_60px_rgba(226,114,65,0.04)] tracking-tight flex-shrink-0 transition-all duration-300 overflow-hidden">
            <div class="mb-4 px-4 pt-2">
                <h2 class="text-xl font-bold text-[#e27241] tracking-tighter">Atmospheric AI</h2>
                <p class="text-[10px] uppercase tracking-widest text-zinc-500">Cinematic Engine</p>
            </div>
            <div class="flex flex-col gap-1">
                <a href="/" class="flex items-center gap-3 px-4 py-3 bg-[#e27241]/10 text-[#e27241] rounded-lg border border-[#e27241]/20 hover:scale-[0.98] transition-all duration-200">
                    <span class="material-symbols-outlined">add_box</span>
                    <span class="text-sm font-medium">New Generation</span>
                </a>
                <a href="/projects" class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 transition-colors hover:bg-white/5 hover:backdrop-blur-xl transition-all">
                    <span class="material-symbols-outlined">history</span>
                    <span class="text-sm font-medium">Recent Projects</span>
                </a>
                <a href="/assets" class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 transition-colors hover:bg-white/5 hover:backdrop-blur-xl transition-all">
                    <span class="material-symbols-outlined">subscriptions</span>
                    <span class="text-sm font-medium">Assets Library</span>
                </a>
                <a href="/settings" class="flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 transition-colors hover:bg-white/5 hover:backdrop-blur-xl transition-all">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="text-sm font-medium">Settings</span>
                </a>
            </div>

            <!-- Histórico de Conversas -->
            <div class="flex-1 overflow-y-auto mt-2 min-h-0">
                <p class="text-[9px] uppercase tracking-widest text-zinc-600 px-3 mb-2">Conversas Recentes</p>
                <div id="chat-history-list" class="flex flex-col gap-0.5">
                    <!-- Preenchido via JS -->
                </div>
            </div>

            <div class="mt-auto border-t border-white/5 pt-4 space-y-1">
                <a href="#" class="w-full flex items-center gap-3 px-4 py-3 text-zinc-500 hover:text-zinc-200 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">help_outline</span>
                    <span class="text-sm font-medium">Help</span>
                </a>
                <button id="logout-btn" class="w-full flex items-center gap-3 px-4 py-3 text-red-500/70 hover:text-red-400 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">logout</span>
                    <span class="text-sm font-medium">Logout</span>
                </button>
                <div class="p-4 bg-[#1a1a1a] rounded-xl ghost-border mb-2 mt-2">
                    <p class="text-[10px] text-[#e27241] uppercase tracking-widest mb-2 font-bold">Pro Plan</p>
                    <p class="text-xs text-zinc-400 mb-3">Unlimited 4K renders and priority queue access.</p>
                    <button class="w-full py-2 bg-[#e27241] text-white text-[10px] font-bold uppercase tracking-widest rounded-sm hover:brightness-110 transition-all">Upgrade to Pro</button>
                </div>
            </div>
        </aside>

        <!-- Main Content + Preview (React island compartilhado) -->
        <main class="flex-1 flex flex-col relative z-10 px-4 py-1 md:px-8 md:py-2 gap-4 overflow-hidden min-w-0">
            <div class="flex flex-col gap-1 flex-shrink-0">
                <h1 class="text-2xl md:text-4xl font-bold text-white tracking-tighter max-w-2xl leading-tight">
                    Create <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e27241] to-[#ffba20]">Visual Realities</span> Through Pure Intent.
                </h1>
                <p class="text-zinc-400 font-light text-xs md:text-sm">Powered by Gemini 2.5 Flash · Veo 3.1</p>
            </div>

            <!-- WorkspaceApp renderiza ChatInterface aqui e PreviewPanel via portal no #preview-root -->
            <WorkspaceApp client:load />
        </main>

        <!-- Preview Panel container (preenchido pelo portal React) -->
        <aside id="preview-root" class="w-96 glass-panel border-l border-white/5 flex flex-col p-6 gap-6 z-10 overflow-y-auto flex-shrink-0 transition-all duration-300"></aside>
    </div>

    <!-- Modal de confirmação de deleção -->
    <div id="delete-modal" class="fixed inset-0 z-[9999] flex items-center justify-center p-4" style="display:none!important">
        <!-- Backdrop -->
        <div id="delete-modal-backdrop" class="absolute inset-0" style="background:rgba(0,0,0,0.7);backdrop-filter:blur(8px)"></div>
        <!-- Card -->
        <div class="relative z-10 w-full max-w-md rounded-2xl border border-white/10 p-6 flex flex-col gap-5" style="background:rgba(18,18,18,0.95)">
            <!-- Ícone -->
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25)">
                    <span class="material-symbols-outlined text-red-400" style="font-size:20px">delete_forever</span>
                </div>
                <div>
                    <p class="text-sm font-semibold text-white">Deletar conversa?</p>
                    <p class="text-[11px] text-zinc-500">Esta ação não pode ser desfeita.</p>
                </div>
            </div>
            <!-- Título da conversa -->
            <div class="rounded-lg px-4 py-3" style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.06)">
                <p class="text-[10px] uppercase tracking-widest text-zinc-600 mb-1">Conversa</p>
                <p id="delete-modal-title" class="text-sm text-zinc-200 font-medium truncate">Sem título</p>
            </div>
            <!-- Botões -->
            <div class="flex gap-3">
                <button id="delete-modal-cancel" class="flex-1 py-2.5 rounded-lg text-sm font-medium text-zinc-400 hover:text-white transition-colors" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08)">Cancelar</button>
                <button id="delete-modal-confirm" class="flex-1 py-2.5 rounded-lg text-sm font-bold text-white transition-all hover:brightness-110 active:scale-95" style="background:linear-gradient(135deg,#dc2626,#b91c1c);border:1px solid rgba(220,38,38,0.3)">
                    <span class="flex items-center justify-center gap-1.5">
                        <span class="material-symbols-outlined" style="font-size:14px">delete</span>
                        Deletar
                    </span>
                </button>
            </div>
        </div>
    </div>

    <script>
        // Logout
        document.getElementById('logout-btn')?.addEventListener('click', () => {
            localStorage.removeItem('visionlabs_token');
            window.location.href = '/landing';
        });

        const menuToggle = document.getElementById('menu-toggle');
        const sidebar = document.getElementById('left-sidebar');
        const mobileOverlay = document.getElementById('mobile-overlay');

        function closeSidebarMobile() {
            sidebar?.classList.remove('mobile-open');
            mobileOverlay?.classList.remove('active');
        }

        if (menuToggle && sidebar) {
            menuToggle.addEventListener('click', () => {
                if (window.innerWidth < 768) {
                    // Mobile: drawer overlay
                    const isOpen = sidebar.classList.contains('mobile-open');
                    if (isOpen) {
                        closeSidebarMobile();
                    } else {
                        sidebar.classList.add('mobile-open');
                        mobileOverlay?.classList.add('active');
                    }
                } else {
                    // Desktop: push content
                    const isOpen = !sidebar.classList.contains('w-0');
                    if (isOpen) {
                        sidebar.classList.remove('w-64', 'p-4', 'border-r');
                        sidebar.classList.add('w-0', 'p-0', 'border-none', 'opacity-0');
                    } else {
                        sidebar.classList.remove('w-0', 'p-0', 'border-none', 'opacity-0');
                        sidebar.classList.add('w-64', 'p-4', 'border-r');
                    }
                }
            });
        }

        // Fechar sidebar ao clicar no overlay (mobile)
        mobileOverlay?.addEventListener('click', closeSidebarMobile);

        // Fechar sidebar automaticamente ao trocar de chat (mobile)
        window.addEventListener('chat:switch-session', () => {
            if (window.innerWidth < 768) closeSidebarMobile();
        });

        // Right Menu Toggle
        const rightToggle = document.getElementById('right-menu-toggle');
        const rightSidebar = document.getElementById('preview-root');

        if (rightToggle && rightSidebar) {
            rightToggle.addEventListener('click', () => {
                const isOpen = !rightSidebar.classList.contains('w-0');
                if (isOpen) {
                    rightSidebar.classList.remove('w-96', 'p-6', 'border-l');
                    rightSidebar.classList.add('w-0', 'p-0', 'border-none', 'opacity-0');
                } else {
                    rightSidebar.classList.remove('w-0', 'p-0', 'border-none', 'opacity-0');
                    rightSidebar.classList.add('w-96', 'p-6', 'border-l');
                }
            });
        }

        // ---- Histórico de sessões ----
        const token = localStorage.getItem('visionlabs_token');
        const historyList = document.getElementById('chat-history-list');
        let activeSessionId = 'default-session';

        async function loadChatHistory() {
            if (!token || !historyList) return;
            try {
                const res = await fetch('/api/chat/sessions', {
                    headers: { Authorization: `Bearer ${token}` }
                });
                const data = await res.json();
                renderHistory(data.sessions || []);
            } catch(e) {
                console.warn('Falha ao carregar histórico de sessões', e);
            }
        }

        function renderHistory(sessions) {
            if (!historyList) return;
            historyList.innerHTML = '';
            if (!sessions.length) {
                historyList.innerHTML = '<p class="text-[10px] text-zinc-700 px-3">Nenhuma conversa ainda</p>';
                return;
            }
            sessions.forEach(s => {
                const title = s.title ? s.title.slice(0, 38) : 'Sem título';
                const item = document.createElement('div');
                item.className = 'chat-history-item' + (s.session_id === activeSessionId ? ' active' : '');
                item.dataset.sessionId = s.session_id;
                item.innerHTML = `
                    <span class="material-symbols-outlined text-[14px] text-zinc-600" style="font-size:14px;flex-shrink:0">chat_bubble</span>
                    <span class="chat-history-title" title="${title}">${title}</span>
                    <button class="chat-history-delete" title="Deletar conversa" data-sid="${s.session_id}">
                        <span class="material-symbols-outlined" style="font-size:14px">delete</span>
                    </button>
                `;
                item.addEventListener('click', (e) => {
                    if (e.target.closest('.chat-history-delete')) return;
                    switchSession(s.session_id, item);
                });
                item.querySelector('.chat-history-delete').addEventListener('click', (e) => {
                    e.stopPropagation();
                    const fullTitle = s.title || 'Sem título';
                    showDeleteModal(s.session_id, fullTitle);
                });
                historyList.appendChild(item);
            });
        }

        function switchSession(sessionId, itemEl) {
            activeSessionId = sessionId;
            document.querySelectorAll('.chat-history-item').forEach(el => el.classList.remove('active'));
            itemEl.classList.add('active');
            // Notifica o React via evento customizado
            window.dispatchEvent(new CustomEvent('chat:switch-session', { detail: { sessionId } }));
        }

        // Escuta nova conversa criada pelo React
        window.addEventListener('chat:new-session', (e) => {
            activeSessionId = e.detail.sessionId;
            setTimeout(loadChatHistory, 2000);
        });

        // ---- Modal de deleção ----
        const deleteModal = document.getElementById('delete-modal');
        const deleteModalTitle = document.getElementById('delete-modal-title');
        const deleteModalCancel = document.getElementById('delete-modal-cancel');
        const deleteModalConfirm = document.getElementById('delete-modal-confirm');
        const deleteModalBackdrop = document.getElementById('delete-modal-backdrop');
        let pendingDeleteSessionId = null;

        function showDeleteModal(sessionId, title) {
            pendingDeleteSessionId = sessionId;
            deleteModalTitle.textContent = title;
            deleteModal.style.removeProperty('display');
            deleteModal.style.display = 'flex';
            // Animação de entrada
            deleteModal.style.opacity = '0';
            deleteModal.querySelector('.relative.z-10').style.transform = 'scale(0.95) translateY(8px)';
            requestAnimationFrame(() => {
                deleteModal.style.transition = 'opacity 0.2s';
                deleteModal.querySelector('.relative.z-10').style.transition = 'transform 0.2s, opacity 0.2s';
                deleteModal.style.opacity = '1';
                deleteModal.querySelector('.relative.z-10').style.transform = 'scale(1) translateY(0)';
            });
        }

        function hideDeleteModal() {
            deleteModal.style.opacity = '0';
            deleteModal.querySelector('.relative.z-10').style.transform = 'scale(0.95) translateY(8px)';
            setTimeout(() => { deleteModal.style.display = 'none'; }, 200);
            pendingDeleteSessionId = null;
        }

        deleteModalCancel?.addEventListener('click', hideDeleteModal);
        deleteModalBackdrop?.addEventListener('click', hideDeleteModal);
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') hideDeleteModal(); });

        deleteModalConfirm?.addEventListener('click', async () => {
            if (!pendingDeleteSessionId) return;
            deleteModalConfirm.disabled = true;
            deleteModalConfirm.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span>';
            try {
                await fetch(`/api/chat/sessions/${pendingDeleteSessionId}`, {
                    method: 'DELETE',
                    headers: { Authorization: `Bearer ${token}` }
                });
                hideDeleteModal();
                loadChatHistory();
            } finally {
                deleteModalConfirm.disabled = false;
                deleteModalConfirm.innerHTML = '<span class="flex items-center justify-center gap-1.5"><span class="material-symbols-outlined" style="font-size:14px">delete</span>Deletar</span>';
            }
        });

        // Carrega ao inicializar
        loadChatHistory();
        // Recarrega a cada 30s
        setInterval(loadChatHistory, 30000);
    </script>
</body>
</html>
